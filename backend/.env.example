# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Local Postgres
DATABASE_URL=postgresql://terratrace:terratrace@localhost:5433/terratrace

# App auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=terratrace_session

# One-time Supabase import only
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/postgres

# Smart recommendation AI/search
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
SMART_RECO_CACHE_TTL_MS=900000
SMART_RECO_MAX_RESULTS=6

# Eco route planner
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# Third Party APIs
FOURSQUARE_API_KEY=your_foursquare_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
